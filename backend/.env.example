# -----------------------------------------------------------------------------
# StudyTrace Backend Environment Configuration (Free Cloud Services)
# Copy this file to '.env' and replace the placeholders with your credentials.
# -----------------------------------------------------------------------------

# 1. Supabase Postgres Connection (Obtain from Settings > Database > Connection String > URI)
# Remember to replace '[YOUR_SUPABASE_PASSWORD]' with your actual database password
DATABASE_URL="postgresql://postgres:[YOUR_SUPABASE_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres"

# 2. Google AI Studio API Key (Obtain from aistudio.google.com)
GEMINI_API_KEY="AIzaSy[YOUR_GEMINI_API_KEY]"

# 3. Pinecone Vector Database Credentials (Obtain from app.pinecone.io)
# Note: Your Pinecone index must be created with Dimension=768 and Metric=cosine to work with Google Embeddings
PINECONE_API_KEY="pcsk_[YOUR_PINECONE_API_KEY]"
PINECONE_HOST="https://[YOUR_INDEX_NAME]-[YOUR_HASH].svc.[YOUR_REGION].pinecone.io"

# 4. Razorpay Webhook Secret (Obtain from Razorpay Dashboard > Settings > Webhooks)
# Used to verify signature of transaction webhooks for user tier upgrades
RAZORPAY_WEBHOOK_SECRET="[YOUR_RAZORPAY_WEBHOOK_SECRET]"

# 5. Local Server Running Port (Optional, defaults to 8080)
PORT=8080
